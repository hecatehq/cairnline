{
  "name": "cairnline-views",
  "private": true,
  "version": "0.0.0",
  "description": "MCP Apps (ui://) views built as native Web Components into self-contained HTML for Cairnline's Go server to embed.",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": "1.3.11"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "vite",
    "dev": "vite",
    "verify": "bun verify/verify.ts",
    "lint": "oxlint -c .oxlintrc.json src",
    "format": "oxfmt --write src vite.config.ts vitest.config.ts index.html",
    "format:check": "oxfmt --check src vite.config.ts vitest.config.ts index.html"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  }
}
