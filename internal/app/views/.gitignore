node_modules/
package-lock.json

# Generated by `bun run verify` (verify.ts screenshot output)
verify/*.png

# Built view bundle: gitignored and produced by `bun run build` (CI/release).
# The .gitkeep placeholder keeps the `//go:embed all:views/dist` directory
# present on a clean checkout so the Go build compiles without a JS build.
dist/*
!dist/.gitkeep
